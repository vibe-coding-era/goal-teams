{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goal-teams.local/schemas/v2.36/attested-identity-registry.schema.json",
  "title": "Goal Teams V2.36 Attested Identity Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "identities"],
  "properties": {
    "schema_version": {"const": "goal-teams-v2.36-attested-identity-registry-v1"},
    "identities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "agent_type",
          "agent_run_id",
          "member_id",
          "display_name",
          "transport_handle",
          "host_attestation"
        ],
        "properties": {
          "agent_type": {"type": "string", "minLength": 1},
          "agent_run_id": {"type": "string", "minLength": 1},
          "member_id": {"type": "string", "minLength": 1},
          "display_name": {"type": "string", "minLength": 1},
          "transport_handle": {"type": "string", "minLength": 1},
          "host_attestation": {
            "$ref": "agent-host-attestation.schema.json"
          }
        },
        "additionalProperties": true
      }
    }
  }
}

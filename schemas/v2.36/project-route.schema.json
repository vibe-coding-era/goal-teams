{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goal-teams.local/schemas/v2.36/project-route.schema.json",
  "title": "Goal Teams V2.36 Derived Project Route Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product_version",
    "target_kind",
    "project_size",
    "work_type",
    "release",
    "ui",
    "backend",
    "api",
    "cli",
    "tests",
    "risk",
    "security_sensitive",
    "external_write",
    "auth",
    "payment",
    "migration",
    "destructive",
    "ui_mode",
    "specialist_requests"
  ],
  "properties": {
    "schema_version": {"const": "goal-teams-project-route-v2.36"},
    "product_version": {"const": "V2.36"},
    "target_kind": {"enum": ["generic_project", "goal_teams_repository"]},
    "project_size": {"enum": ["large", "medium", "small"]},
    "work_type": {"enum": ["feature", "bugfix"]},
    "release": {"type": "boolean"},
    "ui": {"type": "boolean"},
    "backend": {"type": "boolean"},
    "api": {"type": "boolean"},
    "cli": {"type": "boolean"},
    "tests": {"type": "boolean"},
    "risk": {"enum": ["low", "medium", "high", "critical"]},
    "security_sensitive": {"type": "boolean"},
    "external_write": {"type": "boolean"},
    "auth": {"type": "boolean"},
    "payment": {"type": "boolean"},
    "migration": {"type": "boolean"},
    "destructive": {"type": "boolean"},
    "ui_mode": {"enum": ["none", "original", "replica"]},
    "specialist_requests": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["security", "performance", "refactor", "sqa"]}
    },
    "state_gate_profile": {
      "enum": ["goal-teams-core-v2.5", "goal-teams-self-release-v2.36"]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"ui": {"const": false}}, "required": ["ui"]},
      "then": {"properties": {"ui_mode": {"const": "none"}}},
      "else": {"properties": {"ui_mode": {"enum": ["original", "replica"]}}}
    }
  ]
}

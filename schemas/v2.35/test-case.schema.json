{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goal-teams.local/schemas/v2.35/test-case.schema.json",
  "title": "Goal Teams V2.35 Test Case Assertion Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "test_kind",
    "acceptance_refs",
    "test_file_refs",
    "input",
    "processing",
    "expected_output",
    "assertions"
  ],
  "properties": {
    "schema_version": {"const": "goal-teams-test-case-v2.35"},
    "case_id": {"type": "string", "minLength": 1},
    "test_kind": {"enum": ["unit", "tdd", "integration", "e2e", "cli", "api", "fixture"]},
    "acceptance_refs": {"$ref": "#/$defs/nonemptyStringArray"},
    "test_file_refs": {"$ref": "#/$defs/nonemptyStringArray"},
    "input": {"type": "object", "minProperties": 1},
    "processing": {
      "type": "object",
      "minProperties": 3,
      "required": ["kind", "target", "invocation_ref"],
      "properties": {
        "kind": {"enum": ["call", "command", "http", "browser", "fixture_load"]},
        "target": {"type": "string", "minLength": 1},
        "invocation_ref": {"type": "string", "minLength": 1},
        "consumed_input_refs": {"$ref": "#/$defs/nonemptyStringArray"},
        "command": {
          "type": "object",
          "additionalProperties": false,
          "required": ["argv", "cwd"],
          "properties": {
            "argv": {"$ref": "#/$defs/nonemptyStringArray"},
            "cwd": {"type": "string", "minLength": 1}
          }
        }
      },
      "additionalProperties": false
    },
    "expected_output": {
      "type": "object",
      "minProperties": 2,
      "required": ["value", "observable_refs"],
      "properties": {
        "value": {"type": "object", "minProperties": 1},
        "observable_refs": {"$ref": "#/$defs/nonemptyStringArray"},
        "input_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["input_ref", "observable_ref"],
            "properties": {
              "input_ref": {"type": "string", "minLength": 1},
              "observable_ref": {"type": "string", "minLength": 1}
            }
          }
        }
      },
      "additionalProperties": false
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/assertion"}
    },
    "tdd": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "expected_initial_state",
        "test_sha256_ref",
        "preimplementation_tree_ref",
        "domain_log_ref",
        "ledger_event_ref"
      ],
      "properties": {
        "phase": {"const": "pre_implementation"},
        "expected_initial_state": {"const": "red"},
        "test_sha256_ref": {"type": "string", "minLength": 1},
        "preimplementation_tree_ref": {"type": "string", "minLength": 1},
        "domain_log_ref": {"type": "string", "minLength": 1},
        "ledger_event_ref": {"type": "string", "minLength": 1}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"test_kind": {"const": "tdd"}}, "required": ["test_kind"]},
      "then": {"required": ["tdd"]},
      "else": {"not": {"required": ["tdd"]}}
    }
  ],
  "$defs": {
    "nonemptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assertion_id", "actual_ref", "comparator"],
      "properties": {
        "assertion_id": {"type": "string", "minLength": 1},
        "actual_ref": {"type": "string", "minLength": 1},
        "comparator": {
          "enum": [
            "equals",
            "not_equals",
            "contains",
            "member_of",
            "less_than",
            "less_than_or_equal",
            "greater_than",
            "greater_than_or_equal",
            "json_subset",
            "sequence_equals",
            "sha256_equals",
            "exit_code_equals",
            "status_code_equals"
          ]
        },
        "expected_ref": {"type": "string", "minLength": 1},
        "expected_value": true
      },
      "oneOf": [
        {"required": ["expected_ref"], "not": {"required": ["expected_value"]}},
        {"required": ["expected_value"], "not": {"required": ["expected_ref"]}}
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goal-teams.local/schemas/v2.35/version-binding.schema.json",
  "title": "Goal Teams Contract-bound Version Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_version",
    "release_version",
    "artifact_version",
    "contract_ref",
    "contract_sha256",
    "contract_revision",
    "review_ref",
    "review_sha256",
    "review_state"
  ],
  "properties": {
    "schema_version": {"const": "goal-teams-version-binding-v1"},
    "project_version": {"type": "string", "pattern": "^V[0-9]+\\.[0-9]+$"},
    "release_version": {"type": "string", "pattern": "^V[0-9]+\\.[0-9]+$"},
    "artifact_version": {"type": "string", "pattern": "^V[0-9]+\\.[0-9]+(?:-run[0-9]+)?$"},
    "contract_ref": {"type": "string", "minLength": 1},
    "contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contract_revision": {"type": "integer", "const": 2},
    "review_ref": {"type": "string", "minLength": 1},
    "review_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "review_state": {"const": "passed"}
  }
}
